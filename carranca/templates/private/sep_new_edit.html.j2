{# cSpell:ignore tojson unselectable americas #}

{% set dlg_var_icon_url= iconFileUrl %}
{% extends "./layouts/form.html.j2" %}

{# ╒═════════════════════ Inputs ═════════════════════════╕ #}
{% block frm_blc_inputs %}

{# [ Manager (when SepEditMode.FULL_EDIT) #}
{% if (form.manager_name and form.manager_name.data) or formForNew %}
<div class="form-group">
    {# TODO correct 'for' #}
    <label class="frm-label" inert for="{{ form.manager_list.id if formForNew else form.manager_name.id }}">
        {{ managerLabel }}</label>
    <div class="input-group">
        <span class="input-group-text">
            <i class="{{ fi.style }} {{ fi.manager }}" aria-hidden="true"></i>
        </span>
        {% if formForNew %}
        {{ form.manager_list() }}
        {% else %}
        {{ form.manager_name() }}
        {% endif %}

    </div>
</div>
{% endif %}
{# Manager ] #}

{# [ Schema: Select (new) | Input (edit) #}
<div class="form-group mt-2">
    <label class="frm-label" inert for="{{ form.schema_list.id if formForNew else form.schema_name.id }}">
        {{ schemasLabel if formForNew else schemaLabel }}
    </label>
    <div class="input-group">
        <span class="input-group-text">
            <i class="{{ fi.style }} {{ fi.scm }}" aria-hidden="true"></i>
        </span>
        {% if formForNew %}
        {{ form.schema_list() }}
        {% else %}
        {{ form.schema_name() }}
        {% endif %}
    </div>
</div>
{# Schema ] #}

{# [ Visible #}
<div class="form-group mt-2">
    <label class="frm-label" inert for="{{ form.visible.id }}">{{ visibleLabel }}</label>
    <div class="input-group">
        <span class="input-group-text">
            <i class="{{ fi.style }} {{ fi.visible }}" aria-hidden="true"></i>
        </span>
        <span class="input-group-text">
            {{form.visible(class="frm-check-for-bs mt-0") }}
        </span>
    </div>
</div>
{# Visible ] #}

{# [ Name #}
<div class="form-group mt-2">
    <label class="frm-label" inert for="{{ form.sep_name.id }}">{{ sepLabel }}</label>
    <div class="input-group">
        <span class="input-group-text">
            <i class="{{ fi.style }} {{ fi.name }}" aria-hidden="true"></i>
        </span>
        {{ form.sep_name() }}
    </div>
</div>
{# Name ] #}

{# [ Description #}
<div class="form-group mt-2">
    <label class="frm-label" inert for="{{ form.description.id }}">{{ descriptionLabel }}</label>
    <div class="input-group">
        <span class="input-group-text">
            <i class="{{ fi.style }} {{ fi.text }}" aria-hidden="true"></i>
        </span>
        {{ form.description() }}
    </div>
</div>
{# Description ] #}

{# [ spd (SPatial Data File #}
<div class="form-group mt-2">
    <label class="frm-label" inert for="{{ form.spd_name.id }}"> {{ spdLabel }}</label>
    <div class="input-group">
        <span class="input-group-text">
            <i class="{{ fi.style }} {{ fi.spd }}" aria-hidden="true"></i>
        </span>
        {{ form.spd_name() }}
    </div>
</div>
{# spd ] #}

{# [ Icon #}
<div class="form-group mt-2">
    <label class="frm-label" inert for="{{ form.icon_file.id }}">{{ fileLabel }}</label>
    <div class="input-group">
        <span class="input-group-text">
            <i class="{{ fi.style }} {{ fi.image }}" aria-hidden="true"></i>
        </span>
        {{ form.icon_file() }}
    </div>
</div>
{# Icon ] #}

{% endblock frm_blc_inputs %}
{# ╘═════════════════════ Inputs ═════════════════════════╛ #}


{# ╒══════════════ If: New & display -> JS ═══════════════╕ #}

{% block dlg_blc_javascript %}

{% if formForNew and form_display_ui %}
<script>
    const scm_list = document.getElementById('{{ form.schema_list.id }}');
    const mng_list = document.getElementById('{{ form.manager_list.id }}');
    const add_item = (list, id, text) => {
        const option = document.createElement('option');
        option.value = id
        option.textContent = text;
        list.appendChild(option);
    }
    ({{ schemaList | tojson | safe }}).forEach(schema => add_item(scm_list, schema.id, schema.name));
    scm_list.value = '{{ schemaListValue }}';
    ({{ managerList | tojson | safe }}).forEach(manager => add_item(mng_list, manager.id, manager.name));
    mng_list.value = '{{ managerListValue }}';
</script>
{% endif %}

{% endblock dlg_blc_javascript %}

{# ╘══════════════ If: New & display -> JS ═══════════════╛ #}
{# eof #}