{# set a default value for msgOnly #}
{# this form is the only one with user input => submit data entry inputs #}
{% set frm_data_entry_form_id= 'frm-data-entry-form-id' %}
{% set dlg_submit_btn_id= 'dlg-submit-btn-id' %}

{% set form_backend_msg= msgOnly | default(False) %}
{% set form_submit_route = formSubmitRoute | default(None) %}
{% set form_display_ui= not form_backend_msg %}


{% set form_submit_btn_text= form_close_btn_text | default( submitFormButton | default(None)) %}
{% set form_close_btn_text= form_close_btn_text | default( closeFormButton | default(ui_defaults.okButton)) %}

{% extends "./layouts/dialog.html.j2" %}

{# ╒════════════════════ Dialog Body ══════════════════════╕ #}
{% block dlg_blc_body %}

{# ╒═════════ Display Message If Any ═══════════╕ #}
{# always is included, internal filter knows
what should be shown#}
{% include "includes/backend-msg.html.j2" %}
{# ╘═════════ Display Message If Any ═══════════╛ #}

{% if form_display_ui %}
{# ╒═══════════════ Display UI ═══════════════╕ #}
{# FORM: only submit/Post data entry (% frm_blc_inputs %) of the app #}
<form id="{{frm_data_entry_form_id}}" method="post" action="" {{dlg_data_wait_process}} {{formAttribute | default('')}}>
    <input type="hidden" name="{{safe_token.key}}" value="{{safe_token.value}}">
    {# ╒═══════════════ Form's input ═══════════════╕ #}
    {% block frm_blc_inputs %}{% endblock %}
    {# ╘══════════════ Form's input ════════════════╛ #}
</form>

{# ╘═══════════════ Display UI ═══════════════╛ #}
{% endif %}

{% endblock dlg_blc_body %}
{# ╘════════════════════ Dialog Body ══════════════════════╛ #}


{# ╒════════════════ Footer ════════════════════╕ #}

{# ╒════════════ Footer Buttons ══════════╕ #}
{% block dlg_blc_footer_buttons %}

{% if form_display_ui %}

{# ╒═══════════ Display UI ═══════════╕ #}
<div class="col-auto">
    {% from "includes/_action_forms_and_btns.html.j2" import btn_submit %}
    {{ btn_submit(frm_data_entry_form_id, dlg_post_btn_id, form_submit_btn_text) }}
</div>
{# ╘══════════ Display UI ═══════════╛ #}

{% else %}

{# ╒══════ Display Only Message ═════╕ #}
<div class="col-auto">
    {% from "includes/_action_forms_and_btns.html.j2" import btn_close_dlg %}
    {{ btn_close_dlg(dlg_close_form_id, dlg_close_btn_id, form_close_btn_text) }}
</div>
{# ╘══════ Display Only Message ══════╛ #}

{% endif %}
{% endblock dlg_blc_footer_buttons %}
{# ╘════════════ Footer Buttons ══════════╛ #}


{# ╒═══════════ Footer Options ═══════════╕ #}
{% block dlg_blc_footer_options %}
{# optional; for a example see login.html.j2 #}
{% endblock dlg_blc_footer_options %}
{# ╘═══════════ Footer Options ═══════════╛ #}


{% if form_display_ui %}
{# ╒═══════════════ Display UI ═══════════════╕ #}
{# ╒══════ Override dialog ══════╕ #}
{% block dlg_blc_javascript %}
{{ super() }}

{% block frm_blc_script %}
{% endblock frm_blc_script %}

{% endblock dlg_blc_javascript %}
{# ╘══════ Override dialog ══════╛ #}

{% endif %}
{# ╘═══════════════ Display UI ═══════════════╛ #}


{# eof #}