{# cspell:ignore endfrom #}

{% set dlg_cls_size = 'frm-width' %}
{% extends "./layouts/form.html.j2" %}

{% set new_pws = 'fa-key' %}
{% set mrg_top = '' %}


{% block frm_blc_inputs %}

<!-- { Current Password -->
{% if requestCurrentPassword or False %}
<div class="form-group">
    {% from "./includes/_password_field.html.j2" import password_field_input %}
    {{ password_field_input(form.current_password, faStyle, currentPasswordLabel, passwordShow) }}
</div>
{% set new_pws = "fa-circle-plus" %}
{% set mrg_top = "mt-3" %}
{% endif %}
<!-- Current Password } -->


<!-- { New Password -->
<div class="form-group {{ mrg_top }}">
    {% from "./includes/_password_field.html.j2" import password_field_input %}
    {{ password_field_input(form.password, faStyle, newPasswordLabel, passwordShow, new_pws) }}
</div>
<!-- New Password } -->

<!-- { Confirm Password -->
<div class="form-group mt-3">
    {% from "./includes/_password_field.html.j2" import password_field_input %}
    {{ password_field_input(form.confirm_password, faStyle, confirmNewPasswordLabel, passwordShow, 'fa-clone') }}
</div>
<!-- Confirm Password } -->

{% endblock frm_blc_inputs %}
{# eof #}

{# ╒════════════════ Open Eye ══════════════╕ #}
{% block frm_blc_script %}
{% from "./includes/_password_field.js.j2" import password_field_js %}
{{ password_field_js() }}
{% endblock frm_blc_script %}
{# ╘════════════════ Open Eye ══════════════╛ #}
{# eof #}