{# cSpell:ignore tojson unselectable #}

{% set dlg_var_icon_url= iconFileUrl %}
{% set dlg_cls_size= 'modal-xl' %}

{% set id_color_inp= form.color.id %}
{% set id_color_btn= 'id-color-btn' %}
{% set id_color_img= 'id-color-img' %}


{% extends "./layouts/form.html.j2" %}

{# ╒══════════════════════ Inputs ═════════════════════════╕ #}
{% block frm_blc_inputs %}

{# ╒════════════════ Container ════════════════════════╕ #}
<div class="container">
    <div class="row mt-2">
        {# ╒══════════════ Column 1 ═══════════════╕ #}
        <div class="col-12 col-md-5">
            <div class="form-group"> {# [ Name #}
                <label class="frm-label" inert for="{{ form.name.id }}">
                    {{ nameLabel }}
                </label>
                <div class="input-group">
                    <span class="input-group-text">
                        <i class="{{ fi.style }} {{ fi.name }}" aria-hidden="true"></i>
                    </span>
                    {{ form.name() }}
                </div>
            </div> {# Name ] #}

            <div class="form-group mt-3"> {# [ Color #}
                <label class="frm-label" inert for="{{ id_color_inp }}">{{ backColorLabel }}</label>
                <div class="input-group">
                    <span class="input-group-text" style="padding: .2rem .2rem">
                        <button class="input-group-text form-icon-btn" type="button" id="{{id_color_btn}}"
                            title="{{ colorHint | default('Change: Text | Selector')}}">
                            <i class="{{ fi.style }} " aria-hidden="true" data-class='{"text": "fa-keyboard", "color": "fa-palette"}' id="{{id_color_img}}">
                            </i>
                        </button>
                    </span>
                    {{ form.color() }}
                </div>
            </div>{# Color ] #}

            <div class="form-group mt-3"> {# [ Title #}
                <label class="frm-label" inert for="{{ form.title.id }}">
                    {{ titleLabel }}
                </label>
                <div class="input-group">
                    <span class="input-group-text">
                        <i class="{{ fi.style }} {{ fi.title }}" aria-hidden="true"></i>
                    </span>
                    {{ form.title() }}
                </div>
            </div> {# Title ] #}

            <div class="form-group mt-3 mb-3"> {# `mb-3` for Mobile [ Simple Description #}
                <label class="frm-label" inert for="{{ form.description.id }}">
                    {{ descriptionLabel }}
                </label>
                <div class="input-group">
                    <span class="input-group-text">
                        <i class="{{ fi.style }} {{ fi.description }}" aria-hidden="true"></i>
                    </span>
                    {{ form.description() }}
                </div>
            </div> {# Simple Description ] #}

        </div>
        {# ╘═════════════ Column 1 ════════════════╛ #}

        {# ╒══════════════ Column 2 ═══════════════╕ #}
        <div class="col-12 col-md-7">
            <div class="form-group"> {# [ Full Description #}
                <label class="frm-label" inert for="{{form.content.id}}">{{contentLabel}}</label>
                <div class="input-group">
                    <span class="input-group-text">
                        <i class="{{ fi.style }} {{ fi.text }}" aria-hidden="true"></i>
                    </span>
                    {{ form.content(class="form-control h-100") }}
                </div>
            </div> {# Full Description ] #}
        </div>
        {# ╘══════════════ Column 2 ═══════════════╛ #}
    </div>
</div>
{# ╘════════════════ Container ═══════════════════════╛ #}

{% endblock frm_blc_inputs %}
{# ╘══════════════════════ Inputs ═════════════════════════╛ #}

{% block dlg_blc_javascript %}
<script>
    const btnSubmit = document.getElementById('{{ dlg_post_btn_id }}');
    const colorInp = document.getElementById('{{ id_color_inp }}');
    const colorBtn = document.getElementById('{{ id_color_btn }}');
    const colorImg = document.getElementById('{{ id_color_img }}');
</script>
<script src="{{static_route('js/scm_new_edit.js')}}"></script>
{% endblock dlg_blc_javascript %}


{# eof #}