// ==========================================================================
//  Award-winning tidy configuration by gemini
//  Project-level VS Code settings
//  Last updated: 2025-11-10
//  Verified for VS Code ≥ 1.95 and Python ≥ 3.13
//  https://chatgpt.com/share/69121fc6-0d0c-8013-8708-4bf31e095a59
//
//  Last updated: 2026-03-05 (mgd) -
//      Updated Python defaultInterpreterPath
//      python.analysis.exclude - added "**/node_modules", "**/.*",
// ==========================================================================
{
    // === General Editor Settings ===
    "editor.formatOnSave": true,
    // === Language-specific (Python) Overrides ===
    "[python]": {
        "editor.defaultFormatter": "ms-python.black-formatter",
        "editor.formatOnSave": true,
        "editor.tabSize": 4,
        "editor.len": true
    },
    // === GitHub Copilot ===
    // (Disabled or custom configuration placeholder)
    "github.copilot.enable": {
        "*": false,
        "plaintext": false,
        "markdown": false,
        "scminput": false
    },
    // === Python Analysis / Pylance Settings ===
    "python.analysis.autoSearchPaths": true,
    "python.analysis.diagnosticMode": "openFilesOnly",
    "python.analysis.exclude": [
        "**/__pycache__",
        "**/node_modules",
        "**/.*",
        ".env",
        ".git",
        ".venv",
        "venv"
    ],
    "python.analysis.importFormat": "relative",
    "python.analysis.indexing": false,
    "python.analysis.typeCheckingMode": "standard",
    "python.analysis.extraPaths": [
        ".env/Lib/site-packages"
    ],
    // === Environment and Interpreter Settings ===
    // mgd per copitlot  2026.03.05 "python.defaultInterpreterPath": ".env\\Scripts\\python.exe",
    "python.defaultInterpreterPath": "C:\\Program Files\\Python313\\python.exe",
    "python-envs.pythonProjects": []
}