{# only specify value if different from default #}
{% set form_backend_msg= msgOnly | default(False) %}
{% set form_display_msg= msgOnly | default(False) %}
{% set form_display_ui= not form_backend_msg %}
{% set form_close_btn_text= form_close_btn_text | default('Fechar') %}
{% set form_submit_route = fromSubmitRoute | default(None) %}
{% set form_submit_pretend_busy = formSubmitPretendBusy | default(None) %}

{% extends "./layouts/dialog.html.j2" %}

{# ╒════════════════════ Dialog Body ══════════════════════╕ #}
{% block dlg_blc_body %}

{# ╒═════════ Display Message If Any ═══════════╕ #}
{% include "includes/backend-msg.html.j2" %}
{# ╘═════════ Display Message If Any ═══════════╛ #}

{% if form_display_ui %}
    {# ╒═══════════════ Display UI ═══════════════╕ #}
    <form method="post" action="" id="{{dlg_submit_form_id}}" {{ formAttribute | default('') }}>
        <input type="hidden" name="{{safe_token.key}}" value="{{safe_token.value}}">
        {# {{ form.hidden_tag() }} #}
        {# ╒═══════════════ Form's input ═══════════════╕ #}
        {% block frm_blc_inputs %}{% endblock %}
        {# ╘══════════════ Form's input ════════════════╛ #}
    </form>
    {# ╘═══════════════ Display UI ═══════════════╛ #}
{% endif %}


{% endblock dlg_blc_body %}
{# ╘════════════════════ Dialog Body ══════════════════════╛ #}


{# ╒════════════════ Footer ════════════════════╕ #}

{# ╒════════════ Footer Buttons ══════════╕ #}
{% block dlg_blc_footer_buttons %}
{% if form_display_ui %}
    {# ╒═══════════ Display UI ═══════════╕ #}
        <div class="col-auto">
            {% from "includes/_action_forms_and_btns.html.j2" import btn_submit %}
            {{ btn_submit(dlg_submit_form_id, dlg_submit_btn_id, submitButton) }}
        </div>
    {# ╘══════════ Display UI ═══════════╛ #}
{% else %}
    {# ╒══════ Display Only Message ═════╕ #}
        <div class="col-auto">
            {% from "includes/_action_forms_and_btns.html.j2" import btn_close_dlg %}
            {{ btn_close_dlg(dlg_close_form_id, dlg_close_btn_id, form_close_btn_text) }}
        </div>
    {# ╘══════ Display Only Message ══════╛ #}
{% endif %}
{% endblock dlg_blc_footer_buttons %}
{# ╘════════════ Footer Buttons ══════════╛ #}



{# ╒═══════════ Footer Option ════════════╕ #}
{% block dlg_blc_footer_options %}
{# optional; for a example see login.html.j2 #}
{% endblock dlg_blc_footer_options %}
{# ╘═══════════ Footer Option ════════════╛ #}


{% if form_display_ui %}
{# ╒═══════════════ Display UI ═══════════════╕ #}
{# ╒══════ Override dialog ══════╕ #}
{% block dlg_blc_javascript %}
{{ super() }}

{% if form_submit_pretend_busy is not none %}
<script>
    Canoa.afterSubmitPretendBusy = {{ form_submit_pretend_busy | tojson }};
</script>
{% endif %}

{% block frm_blc_script %}
{% endblock frm_blc_script %}

{% endblock dlg_blc_javascript %}
{# ╘══════ Override dialog ══════╛ #}

{% endif %}
{# ╘═══════════════ Display UI ═══════════════╛ #}


{% if form_submit_route %}
{# ╒════════════════ Dialog Forms ════════════════╕ #}
{% block dlg_blc_forms %}

{% from "includes/_action_forms_and_btns.html.j2" import action_form__submit_cargo %}
{{ action_form__submit_cargo(dlg_submit_form_id, form_submit_route ) }}

{% endblock dlg_blc_forms %}
{# ╘═════════════════ Dialog Forms ════════════════╛ #}
{% endif %}

{# eof #}